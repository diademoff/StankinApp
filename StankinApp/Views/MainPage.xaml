<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StankinApp.MainPage"
             xmlns:local="clr-namespace:StankinApp.ViewModels"
             xmlns:model="clr-namespace:StankinApp.Core.ScheduleModel;assembly=StankinApp.Core"
             x:DataType="local:MainViewModel">

    <ContentPage.BindingContext>
        <local:MainViewModel/>
    </ContentPage.BindingContext>
    
    <ScrollView>
        <CollectionView ItemsSource="{Binding Schedule}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:DateSchedule">
                    <Grid RowDefinitions="auto, *">
                        <!--Дата-->
                        <Label Text="{Binding Date, StringFormat='{0:dd MMMM, dddd}'}" 
                               FontAttributes="Bold" 
                               Margin="10,5"
                               Grid.Row="0"/>

                        <!--Расписание на дату-->
                        <CollectionView ItemsSource="{Binding Courses}" 
                                        Grid.Row="1" 
                                        Margin="10,25"
                                        ItemTemplate="{StaticResource CourseTemlate}">
                        </CollectionView>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </ScrollView>

</ContentPage>
