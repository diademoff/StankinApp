<sukiUi:SukiWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:StankinApp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:StankinApp.Views"
        xmlns:sukiUi="clr-namespace:SukiUI.Controls;assembly=SukiUI"
        mc:Ignorable="d" d:DesignWidth="375" d:DesignHeight="650"
        x:Class="StankinApp.Views.MainWindow"
        Icon="/Assets/avalonia-logo.ico"
        Title="StankinApp">
        <views:MainView />
</sukiUi:SukiWindow>
